# Django core settings
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# Leave DATABASE_URL empty to keep the local SQLite fallback.
DATABASE_URL=

# Optional public exposure flags.
# By default both follow DEBUG:
# - local/debug => True
# - production with DEBUG=False => False
# SHOW_DEMO_ACCESS=
# ALLOW_PUBLIC_REGISTRATION=

# Example production PostgreSQL URL:
# DATABASE_URL=postgresql://crm_user:change-me@db-host:5432/crm_db
